# ============================================================
# BTSSS — Production Environment Variables
# Copy this file to .env and fill in the values.
# WARNING: NEVER commit the real .env file to the repository!
# ============================================================

# --- Database ---
DB_PASSWORD=your_secure_password_here
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/diploma_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# --- Admin account ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
ADMIN_EMAIL=admin@example.com

# --- JWT ---
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_minimum_32_chars
BTSSS_APP_JWTSECRET=your_very_long_and_secure_jwt_secret_key_here_minimum_32_chars
BTSSS_APP_JWTEXPIRATIONMS=86400000

# --- Cloudinary (cloud file storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Storage strategy: local or cloudinary ---
BTSSS_APP_STORAGE=cloudinary

# --- Frontend ---
# Full URL of the backend API, accessible from the browser
REACT_APP_API_URL=http://your-server-ip-or-domain:8080

# --- CORS allowed origins ---
# Comma-separated list of frontend URLs allowed to access the API
ALLOWED_ORIGINS=http://your-server-ip-or-domain,https://your-domain.com

# --- Email (optional SMTP config) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
